{
  "manifest_version": 3,
  "name": "Ordforråd",
  "version": "0.1.0",
  "description": "Right-click any word to build vocabulary cards with a local LLM and export to Anki.",

  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "notifications"
  ],

  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Ordforråd"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
